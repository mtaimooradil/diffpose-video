# Model weights and large binaries
*.pth
*.bin
*.npz
*.pkl

# Data and output directories
data/
checkpoints/
results/
exp/
videos/
visualisations/

# User TOML configs (may contain real paths) — keep bundled examples in configs/
configs/*.toml
!configs/infer.toml
!configs/explore.toml
!configs/visualise.toml

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Editor and OS
.DS_Store
.idea/
.vscode/
*.swp

# Secrets
.env
